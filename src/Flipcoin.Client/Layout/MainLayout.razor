@inherits LayoutComponentBase
@inject AuthService AuthService
@inject WalletState WalletState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="page">
    <nav class="navbar navbar-expand navbar-dark flip-navbar px-3">
        <a class="navbar-brand fw-bold" href="">🪙 Flipcoin</a>
        <AuthorizeView>
            <Authorized>
                <div class="navbar-nav me-auto">
                    @if (context.User.IsInRole("Admin"))
                    {
                        <NavLink class="nav-link" href="admin/wallets">Admin</NavLink>
                    }
                    else
                    {
                        <NavLink class="nav-link" href="game">Console</NavLink>
                        <NavLink class="nav-link" href="wallet">Wallet</NavLink>
                        <NavLink class="nav-link" href="transfer">Transfer</NavLink>
                    }
                </div>
                <div class="navbar-nav align-items-center">
                    @if (!context.User.IsInRole("Admin"))
                    {
                        <span class="navbar-text me-3"><span class="badge bg-warning text-dark"><LiveBalance /></span></span>
                    }
                    <span class="navbar-text me-3 small">@context.User.Identity?.Name</span>
                    <button class="btn btn-outline-light btn-sm" @onclick="LogoutAsync">Logout</button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="navbar-nav ms-auto">
                    <NavLink class="nav-link" href="login">Login</NavLink>
                    <NavLink class="nav-link" href="register">Register</NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>

    <main class="container py-4">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // If the user is already signed in (e.g. after a page refresh), start the
        // real-time wallet state. StartAsync is idempotent, so login also calling
        // it is harmless.
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true && !state.User.IsInRole("Admin"))
        {
            await WalletState.StartAsync();
        }
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("login");
    }
}
