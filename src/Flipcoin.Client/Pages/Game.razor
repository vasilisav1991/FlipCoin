@page "/game"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject WalletState WalletState
@inject IJSRuntime JS

<PageTitle>Flipcoin</PageTitle>

<div class="flip-panel">
    <section class="dash-main">
        <div class="dash-head">
            <div>
                <div class="mono-label">Available balance</div>
                <div class="dash-balance">@WalletState.Balance.ToString("N2")<span class="unit">FLIP</span></div>
                @if (WalletState.HasWallet)
                {
                    <div class="small text-muted mt-2 d-flex align-items-center gap-2">
                        <code>@WalletState.Address</code>
                        <button class="btn btn-sm btn-outline-secondary py-0" @onclick="CopyAddressAsync">@(_copied ? "Copied!" : "Copy")</button>
                    </div>
                }
            </div>
            <div class="status-pill"><span class="dot"></span> Server authoritative</div>
        </div>
        <hr class="flip-divider my-3" />

        @if (_error is not null)
        {
            <div class="alert alert-danger">@_error</div>
        }

        <div class="play-grid">
            <div>
                <div class="coin @CoinClass">
                    <div class="coin-face coin-heads">H</div>
                    <div class="coin-face coin-tails">T</div>
                </div>

                @if (_result is not null && !_flipping)
                {
                    <div class="text-center mb-3">
                        <span class="@(_result.Won ? "text-success" : "")" style="@(_result.Won ? "" : "color:var(--orange)")">
                            Landed <strong>@_result.Outcome</strong> —
                            @(_result.Won ? $"won +{_result.Payout:N2} FLIP" : "no payout")
                        </span>
                    </div>
                }

                <div class="choice-row mb-3">
                    <button class="choice-btn @(_choice == "Heads" ? "active" : "")" @onclick='() => _choice = "Heads"' disabled="@_flipping">Heads</button>
                    <button class="choice-btn @(_choice == "Tails" ? "active" : "")" @onclick='() => _choice = "Tails"' disabled="@_flipping">Tails</button>
                </div>

                <div class="d-flex justify-content-between mono-label mb-1">
                    <span>Bet</span>
                    <span>@_bet.ToString("N2") FLIP</span>
                </div>
                <div class="bet-row mb-2">
                    @foreach (var amount in BetPresets)
                    {
                        <button class="bet-chip @(_bet == amount ? "active" : "")" @onclick="() => _bet = amount"
                                disabled="@(_flipping || amount > WalletState.Balance)">@amount.ToString("N0")</button>
                    }
                </div>
                <input type="number" min="0.01" step="1" class="form-control mb-2" @bind="_bet"
                       placeholder="Custom bet" disabled="@_flipping" />

                @if (_bet <= 0)
                {
                    <div class="small" style="color: var(--orange);">Bet must be greater than zero.</div>
                }
                else if (_bet > WalletState.Balance)
                {
                    <div class="small" style="color: var(--orange);">Insufficient balance for this bet.</div>
                }

                <button class="btn btn-flip w-100 mt-3 py-2" @onclick="PlayAsync" disabled="@(_flipping || _bet <= 0 || _bet > WalletState.Balance)">
                    @(_flipping ? "Flipping…" : "Flip the coin")
                </button>
            </div>

            <div class="d-flex flex-column gap-3">
                <div>
                    <button class="send-toggle @(_activityOpen ? "open" : "")" @onclick="() => _activityOpen = !_activityOpen">
                        <span>Activity</span>
                        <span class="chevron @(_activityOpen ? "open" : "")">›</span>
                    </button>
                    @if (_activityOpen)
                    {
                        <div class="send-body">
                            @if (_ledger is null || _ledger.Count == 0)
                            {
                                <div class="text-muted small">No activity yet — flip to begin.</div>
                            }
                            else
                            {
                                <div class="activity-list">
                                    @foreach (var t in _ledger.Take(10))
                                    {
                                        <div class="activity-item">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="badge @BadgeClass(t.Type)">@t.Type</span>
                                                <span class="fw-semibold">@Signed(t) FLIP</span>
                                            </div>
                                            <div class="d-flex justify-content-between small text-muted mt-1">
                                                <span class="text-truncate" style="max-width: 55%;">
                                                    @(t.CounterpartyAddress is null ? "—" : $"↔ {t.CounterpartyAddress}")
                                                </span>
                                                <span>@t.Timestamp.ToLocalTime().ToString("dd MMM, HH:mm")</span>
                                            </div>
                                            <div class="small text-muted">Balance after: @t.BalanceAfter.ToString("N2")</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <div>
                    <button class="send-toggle @(_sendOpen ? "open" : "")" @onclick="() => _sendOpen = !_sendOpen">
                        <span>Send FLIP</span>
                        <span class="chevron @(_sendOpen ? "open" : "")">›</span>
                    </button>
                    @if (_sendOpen)
                    {
                        <div class="send-body">
                            <EditForm Model="_send" OnValidSubmit="SendAsync">
                                <DataAnnotationsValidator />
                                <div class="mb-3">
                                    <label class="mono-label">Recipient address</label>
                                    <InputText class="form-control" @bind-Value="_send.ToAddress" placeholder="FLIP-xxxxxxxx"
                                               @onfocus="() => _recentOpen = true" autocomplete="off" />
                                    <ValidationMessage For="() => _send.ToAddress" class="text-danger small" />
                                    @if (_recentOpen && RecentAddresses.Any())
                                    {
                                        <div class="recent-addr mt-1">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="mono-label">Recently used</span>
                                                <button type="button" class="btn-close-recent" @onclick="() => _recentOpen = false">✕</button>
                                            </div>
                                            @foreach (var addr in RecentAddresses)
                                            {
                                                <button type="button" class="recent-addr-item" @onclick="() => PickAddress(addr)">@addr</button>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="mb-3">
                                    <label class="mono-label">Amount</label>
                                    <InputNumber class="form-control" @bind-Value="_send.Amount" />
                                    <ValidationMessage For="() => _send.Amount" class="text-danger small" />
                                    @if (_send.Amount > WalletState.Balance)
                                    {
                                        <div class="small mt-1" style="color: var(--orange);">
                                            Exceeds your balance (@WalletState.Balance.ToString("N2") FLIP).
                                        </div>
                                    }
                                </div>
                                @if (_sendError is not null)
                                {
                                    <div class="alert alert-danger py-2">@_sendError</div>
                                }
                                @if (_sendSuccess is not null)
                                {
                                    <div class="alert alert-success py-2">@_sendSuccess</div>
                                }
                                <button class="btn btn-primary w-100" type="submit"
                                        disabled="@(_sending || _send.Amount <= 0 || _send.Amount > WalletState.Balance)">
                                    @(_sending ? "Sending…" : "Send FLIP")
                                </button>
                            </EditForm>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private static readonly decimal[] BetPresets = { 10m, 50m, 100m, 250m };

    private string _choice = "Heads";
    private decimal _bet = 50m;
    private bool _flipping;
    private PlayResult? _result;
    private List<TransactionDto>? _ledger;
    private bool _copied;
    private string? _error;

    private bool _activityOpen = true;

    private bool _sendOpen;
    private bool _recentOpen;
    private readonly SendModel _send = new();
    private bool _sending;
    private string? _sendError;
    private string? _sendSuccess;

    // Addresses this user has recently sent to (from their own TransferOut entries).
    private IEnumerable<string> RecentAddresses =>
        (_ledger ?? Enumerable.Empty<TransactionDto>())
            .Where(t => t.Type == "TransferOut" && !string.IsNullOrEmpty(t.CounterpartyAddress))
            .Select(t => t.CounterpartyAddress!)
            .Distinct()
            .Take(5);

    private string CoinClass => _flipping
        ? "flipping"
        : _result is null ? string.Empty : (_result.Outcome == "Tails" ? "show-tails" : "show-heads");

    protected override async Task OnInitializedAsync()
    {
        WalletState.OnChange += OnWalletChanged;
        await WalletState.StartAsync();
        await LoadLedgerAsync();
    }

    private async void OnWalletChanged()
    {
        await LoadLedgerAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadLedgerAsync()
    {
        try
        {
            _ledger = (await Api.GetTransactionsAsync(1, 25)).Items;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task PlayAsync()
    {
        // Guard client-side so we don't fire a request that can only fail; the
        // server re-validates the stake regardless.
        if (_bet <= 0 || _bet > WalletState.Balance)
        {
            return;
        }

        _error = null;
        _result = null;
        _flipping = true;
        try
        {
            var play = Api.PlayAsync(_choice, _bet);
            await Task.WhenAll(play, Task.Delay(900));
            _result = await play;
            WalletState.SetBalance(_result.NewBalance);
            await LoadLedgerAsync();
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _flipping = false;
        }
    }

    private async Task SendAsync()
    {
        // Don't send a request that can only fail; the server re-validates too.
        if (_send.Amount > WalletState.Balance)
        {
            _sendError = "Insufficient balance for this transfer.";
            return;
        }

        _sending = true;
        _sendError = null;
        _sendSuccess = null;
        try
        {
            var result = await Api.TransferAsync(_send.ToAddress, _send.Amount);
            WalletState.SetBalance(result.NewBalance);
            await LoadLedgerAsync();
            _sendSuccess = $"Sent {result.Amount:N2} FLIP to {result.ToAddress}.";
            _send.ToAddress = string.Empty;
            _send.Amount = 0;
        }
        catch (ApiException ex)
        {
            _sendError = ex.Message;
        }
        finally
        {
            _sending = false;
        }
    }

    private void PickAddress(string address)
    {
        _send.ToAddress = address;
        _recentOpen = false;
    }

    private async Task CopyAddressAsync()
    {
        if (WalletState.Address is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", WalletState.Address);
        _copied = true;
    }

    // Credits are shown as +, debits as -.
    private static string Signed(TransactionDto t)
    {
        var debit = t.Type is "TransferOut" or "Stake";
        return $"{(debit ? "-" : "+")}{t.Amount:N2}";
    }

    private static string BadgeClass(string type) => type switch
    {
        "TransferIn" or "Payout" => "bg-success",
        "TransferOut" or "Stake" => "bg-secondary",
        _ => "bg-info"
    };

    public void Dispose() => WalletState.OnChange -= OnWalletChanged;

    private sealed class SendModel
    {
        [Required]
        public string ToAddress { get; set; } = string.Empty;

        [Range(0.0001, double.MaxValue, ErrorMessage = "Amount must be greater than zero.")]
        public decimal Amount { get; set; }
    }
}
