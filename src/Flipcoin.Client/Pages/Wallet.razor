@page "/wallet"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject WalletState WalletState
@inject IJSRuntime JS

<PageTitle>Wallet — Flipcoin</PageTitle>

<h1 class="h3 mb-3">My wallet</h1>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (!WalletState.HasWallet)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-5">
            <div class="card flip-card h-100">
                <div class="card-body">
                    <div class="text-muted small">Balance</div>
                    <div class="display-6">@WalletState.Balance.ToString("N2") <span class="fs-6 text-muted">FLIP</span></div>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card flip-card h-100">
                <div class="card-body">
                    <div class="text-muted small">Wallet address</div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <code class="fs-6">@WalletState.Address</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CopyAddressAsync">
                            @(_copied ? "Copied!" : "Copy")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5">Transaction history</h2>
    @if (_transactions is null)
    {
        <p class="text-muted">Loading…</p>
    }
    else if (_transactions.Items.Count == 0)
    {
        <p class="text-muted">No transactions yet — play a round or receive a transfer.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th class="text-end">Amount</th>
                        <th>Counterparty</th>
                        <th>When</th>
                        <th class="text-end">Balance after</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _transactions.Items)
                    {
                        <tr>
                            <td><span class="badge @BadgeClass(t.Type)">@t.Type</span></td>
                            <td class="text-end">@t.Amount.ToString("N2")</td>
                            <td>@(t.CounterpartyAddress ?? "—")</td>
                            <td class="small text-muted">@t.Timestamp.ToLocalTime().ToString("g")</td>
                            <td class="text-end">@t.BalanceAfter.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <span class="small text-muted">Page @_page · @_transactions.TotalCount total</span>
            <div class="btn-group">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(_page <= 1)" @onclick="() => ChangePageAsync(-1)">Prev</button>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasNext)" @onclick="() => ChangePageAsync(1)">Next</button>
            </div>
        </div>
    }
}

@code {
    private const int PageSize = 10;

    private PagedResult<TransactionDto>? _transactions;
    private int _page = 1;
    private bool _copied;
    private string? _error;

    private bool HasNext => _transactions is not null && _page * PageSize < _transactions.TotalCount;

    protected override async Task OnInitializedAsync()
    {
        WalletState.OnChange += OnWalletChanged;
        await WalletState.StartAsync();
        await LoadTransactionsAsync();
    }

    // A real-time balance change means new history — reload the current page.
    private async void OnWalletChanged()
    {
        await LoadTransactionsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadTransactionsAsync()
    {
        try
        {
            _transactions = await Api.GetTransactionsAsync(_page, PageSize);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ChangePageAsync(int delta)
    {
        _page += delta;
        await LoadTransactionsAsync();
    }

    private async Task CopyAddressAsync()
    {
        if (WalletState.Address is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", WalletState.Address);
        _copied = true;
    }

    private static string BadgeClass(string type) => type switch
    {
        "Reward" or "TransferIn" or "Payout" => "bg-success",
        "TransferOut" or "Stake" => "bg-secondary",
        _ => "bg-info"
    };

    public void Dispose() => WalletState.OnChange -= OnWalletChanged;
}
