@page "/"

<PageTitle>Flipcoin</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="text-center py-4">
            <h1 class="display-5">🪙 Flipcoin</h1>
            <p class="text-muted">Welcome back, @context.User.Identity?.Name.</p>
            <div class="d-flex gap-2 justify-content-center mt-3">
                @if (context.User.IsInRole("Admin"))
                {
                    <a class="btn btn-primary" href="admin/wallets">Open the admin dashboard</a>
                }
                else
                {
                    <a class="btn btn-primary" href="game">Open the console</a>
                    <a class="btn btn-outline-primary" href="wallet">My wallet</a>
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="text-center py-5">
            <h1 class="display-4">🪙 Flipcoin</h1>
            <p class="lead text-muted">Hold FLIP, play the flip, and transfer coins to other wallets.</p>
            <div class="d-flex gap-2 justify-content-center mt-4">
                <a class="btn btn-primary btn-lg" href="login">Log in</a>
                <a class="btn btn-outline-primary btn-lg" href="register">Create account</a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
